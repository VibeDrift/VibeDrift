{
  "name": "@vibedrift/cli",
  "version": "0.14.9",
  "description": "Ship agentic. Stay coherent. Self-checking code integrity for AI coding agents, in the loop via MCP.",
  "type": "module",
  "bin": {
    "vibedrift": "bin/vibedrift.mjs"
  },
  "main": "./dist/cli/index.js",
  "exports": {
    ".": "./dist/cli/index.js",
    "./render": "./dist/render.js",
    "./tools": "./dist/tools-core/index.js"
  },
  "files": [
    "dist",
    "bin",
    "skills"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "typecheck:eval": "tsc -p tsconfig.eval.json",
    "eval": "tsx eval/run.ts",
    "eval:analyze": "tsx eval/analyze.ts",
    "calibrate": "tsx test/calibration/precision-recall.ts",
    "calibrate:monotonic": "tsx test/calibration/run.ts",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "vibe-coding",
    "code-consistency",
    "static-analysis",
    "ai-generated-code",
    "drift-detection",
    "convention-drift",
    "ai-codebase",
    "code-audit"
  ],
  "author": "Sami Khan",
  "license": "MIT",
  "homepage": "https://vibedrift.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VibeDrift/VibeDrift.git"
  },
  "bugs": {
    "url": "https://github.com/VibeDrift/VibeDrift/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "ignore": "^7.0.5",
    "ora": "^9.3.0",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.25.10",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@eslint/js": "^10.0.1",
    "@supabase/supabase-js": "^2.103.0",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
