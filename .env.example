# VibeDrift CLI environment variables
# None are required for basic usage — these are for advanced/CI setups.

# Bearer token for CI/CD (overrides ~/.vibedrift/config.json)
# Get one from: vibedrift.ai/dashboard → Settings → API Tokens
# VIBEDRIFT_TOKEN=vd_live_xxxxxxxxxxxx

# Override the API base URL (for staging or self-hosted deployments)
# VIBEDRIFT_API_URL=https://vibedrift-api.fly.dev

# Set to "1" to prevent the CLI from auto-opening the browser during login
# VIBEDRIFT_NO_BROWSER=1

# npm publish token (maintainer only)
# NPM_TOKEN=npm_xxxxxxxxxxxx
